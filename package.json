{
  "name": "@pepps233/mendr",
  "version": "0.2.0",
  "description": "Autonomous pull request review agent CLI.",
  "type": "module",
  "bin": {
    "mendr": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/cli.ts src/daemon.ts --format esm --dts --clean --external react",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:e2e": "MENDR_E2E=1 vitest run test/e2e",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "github",
    "pull-request",
    "codex",
    "claude"
  ],
  "homepage": "https://github.com/Pepps233/mendr#readme",
  "bugs": {
    "url": "https://github.com/Pepps233/mendr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pepps233/mendr.git"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.6.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.31",
    "@vitest/coverage-v8": "^2.1.9",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
